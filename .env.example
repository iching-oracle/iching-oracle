# Database (SQLite for development; switch to PostgreSQL in production)
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL (required for OAuth callbacks)
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Both must be set or Google sign-in is disabled (empty values cause Configuration errors).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: PostgreSQL for production
# DATABASE_URL="postgresql://user:password@host:5432/iching_oracle?schema=public"

# Future Stripe integration
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
