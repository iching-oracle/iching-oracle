generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Pooled/runtime URL (PgBouncer, Neon pooler, Prisma Accelerate prisma://…)
  url       = env("DATABASE_URL")
  /// Direct connection for migrations only — set to non-pooled URL in production
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified            DateTime?
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  passwordResetTokenHash   String?   @unique
  passwordResetExpires     DateTime?
  image                    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  premiumUntil                  DateTime?
  stripeCustomerId              String?   @unique
  stripeSubscriptionId          String?
  subscriptionStatus            String    @default("free")
  subscriptionCurrentPeriodEnd  DateTime?
  planType                      String    @default("FREE")
  credits                       Int       @default(10)
  /// Monthly/daily quota cap (reset target, not accumulated balance)
  monthlyCredits                Int       @default(10)
  lifetimeCreditsUsed           Int       @default(0)
  lastCreditRefillAt            DateTime?
  creditsResetAt                DateTime?
  /// Stripe billing period end when credits were last reset
  lastCreditRefillPeriodEnd     DateTime?
  preferredLanguage    String  @default("de")
  memoryEnabled        Boolean   @default(true)
  memoryLastExtractedAt DateTime?
  role                 String    @default("USER")

  /// Closed beta program
  isBetaMember         Boolean   @default(false)
  betaJoinedAt         DateTime?
  inviteCodeUsed       String?
  inviteCodeId         String?

  accounts Account[]
  supportTickets SupportTicket[]
  memories Memory[]
  memoryEvents MemoryEvent[]
  aiUsages AIUsage[]
  creditTransactions CreditTransaction[]
  sessions Session[]
  readings              Reading[]
  readingConversations  ReadingConversation[]
  oracleConversations   OracleConversation[]
  patternInsightCache   PatternInsightCache?
  insightReportCaches   InsightReportCache[]
  oracleMilestones      OracleMilestone[]
  dailyOracles  DailyOracle[]
  dailyStreak   Int @default(0)
  lastDailyVisit DateTime?
  lastActivityAt DateTime?

  /// Email lifecycle preferences (GDPR; transactional auth emails always allowed)
  emailDailyGuidance      Boolean  @default(true)
  emailWeeklyReflection   Boolean  @default(true)
  emailReengagement       Boolean  @default(true)
  emailProductUpdates     Boolean  @default(false)
  emailMarketing          Boolean  @default(false)
  emailUnsubscribeToken   String?  @unique
  emailGlobalUnsubscribedAt DateTime?
  lastDailyEmailAt        DateTime?
  lastWeeklyEmailAt       DateTime?
  lastReengagementEmailAt DateTime?
  lastReengagementTier    Int?

  emailSendLogs EmailSendLog[]
  creditBillingRefills CreditBillingRefill[]
  readingFeedbacks ReadingFeedback[]
  productFeedbacks ProductFeedback[]
  waitlistEntry WaitlistEntry?
  inviteCode    InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)
}

model CreditBillingRefill {
  id              String   @id @default(cuid())
  userId          String
  stripeInvoiceId String?  @unique
  periodStart     DateTime
  periodEnd       DateTime
  quota           Int
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodEnd])
  @@index([userId, createdAt(sort: Desc)])
}

model EmailSendLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  resendId  String?
  subject   String?
  openedAt  DateTime?
  clickedAt DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

model Reading {
  id                  String   @id @default(cuid())
  userId              String
  question            String
  hexagram            Int
  primaryHexagramName String?
  lineValues          String
  changingLines       String?
  transformedHexagram Int?
  finalHexagramName   String?
  interpretation         String   @db.Text
  interpretationPending  Boolean  @default(false)
  isPremiumReading       Boolean  @default(false)
  interpretationMode     String   @default("traditional")
  summary                String?  @db.Text
  category               String   @default("general")
  isFavorite             Boolean  @default(false)
  notes                  String?  @db.Text
  language               String   @default("de")
  isPublic               Boolean  @default(false)
  shareId                String?  @unique
  publicSlug             String?  @unique
  seoTitle               String?
  seoDescription         String?  @db.Text
  seoIndexable           Boolean  @default(false)
  viewCount              Int      @default(0)
  shareCount             Int      @default(0)
  publishedAt            DateTime?
  createdAt              DateTime @default(now())

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation      ReadingConversation?
  oracleConversation OracleConversation?
  seoPage           SeoPage?
  milestones        OracleMilestone[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite])
  @@index([userId, category])
  @@index([seoIndexable, publishedAt(sort: Desc)])
}

/// Programmatic and editorial SEO landing pages (hexagram topics, clusters, guides).
model SeoPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  type            String
  templateKey     String
  hexagramNumber  Int?
  topic           String?
  title           String
  metaTitle       String
  metaDescription String   @db.Text
  canonicalPath   String   @unique
  content         Json
  wordCount       Int      @default(0)
  status          String   @default("published")
  noindex         Boolean  @default(false)
  readingId       String?  @unique
  viewCount       Int      @default(0)
  shareCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reading Reading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([hexagramNumber, topic])
  @@index([status, updatedAt(sort: Desc)])
}

/// Lightweight SEO / growth analytics events.
model SeoAnalyticsEvent {
  id        String   @id @default(cuid())
  path      String
  event     String
  source    String?
  keyword   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([path, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
}

model ReadingConversation {
  id        String   @id @default(cuid())
  readingId String   @unique
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reading  Reading               @relation(fields: [readingId], references: [id], onDelete: Cascade)
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation ReadingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

/// Conversational oracle sessions (pre/post reading); separate from ReadingConversation follow-up.
model OracleConversation {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("active")
  readingId String?  @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading  Reading?        @relation(fields: [readingId], references: [id], onDelete: SetNull)
  messages OracleMessage[]

  @@index([userId, updatedAt(sort: Desc)])
}

model OracleMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation OracleConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyOracle {
  id                String   @id @default(cuid())
  userId            String?
  visitorKey        String?
  date              DateTime @db.Date
  hexagramNumber    Int
  lineValues        String
  oracleMessage     String   @db.Text
  emotionalInsight  String   @db.Text
  recommendedAction String   @db.Text
  caution           String   @db.Text
  reflectionQuote   String   @db.Text
  luckyFocus        String
  energyLevel       Int      @default(50)
  energyTheme       String   @default("balanced")
  interpretation    String   @db.Text
  isFavorite        Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@unique([visitorKey, date])
  @@index([userId, date(sort: Desc)])
  @@index([visitorKey, date(sort: Desc)])
}

model PatternInsightCache {
  userId      String   @id
  revision    String
  payload     Json
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Cached weekly / monthly AI reflection reports (premium).
model InsightReportCache {
  id          String   @id @default(cuid())
  userId      String
  reportType  String
  periodKey   String
  revision    String
  payload     Json
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportType, periodKey])
  @@index([userId, reportType, generatedAt(sort: Desc)])
}

/// User-curated spiritual milestones and saved insight moments.
model OracleMilestone {
  id        String   @id @default(cuid())
  userId    String
  title     String
  note      String?  @db.Text
  kind      String   @default("milestone")
  readingId String?
  metadata  Json?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reading Reading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, kind])
}

model AIUsage {
  id                  String   @id @default(cuid())
  userId              String
  featureType         String
  creditsUsed         Int
  estimatedTokenUsage Int?
  estimatedCostUsd    Float?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, featureType])
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Compressed spiritual companion memories — themes, not raw transcripts.
model Memory {
  id               String    @id @default(cuid())
  userId           String
  type             String
  summary          String    @db.Text
  confidence       Float     @default(0.5)
  tags             String[]  @default([])
  occurrenceCount  Int       @default(1)
  lastReferencedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     MemoryEvent[]
  references MemoryReference[]

  @@index([userId, type])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, lastReferencedAt(sort: Desc)])
}

model MemoryEvent {
  id        String   @id @default(cuid())
  userId    String
  memoryId  String?
  source    String
  sourceId  String?
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory Memory? @relation(fields: [memoryId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
}

model MemoryReference {
  id        String   @id @default(cuid())
  userId    String
  memoryId  String
  context   String
  contextId String?
  createdAt DateTime @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model WaitlistEntry {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  source           String?
  referrer         String?
  referralCode     String?
  status           String    @default("pending")
  waitlistPosition Int?
  invitedAt        DateTime?
  joinedAt         DateTime?
  userId           String?   @unique
  inviteCodeId     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  inviteCode InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  email       String?
  note        String?
  source      String?
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  waitlistEntries WaitlistEntry[]
  users           User[]

  @@index([email])
  @@index([source])
  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

model ReadingFeedback {
  id        String   @id @default(cuid())
  userId    String
  readingId String
  resonance String
  comment   String?  @db.Text
  category  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, readingId])
  @@index([resonance, createdAt(sort: Desc)])
}

model ProductFeedback {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  message   String   @db.Text
  /// 1–5 satisfaction pulse (optional)
  rating    Int?
  severity  String?
  flow      String?
  pagePath  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model BetaAnnouncement {
  id          String   @id @default(cuid())
  title       String
  body        String   @db.Text
  type        String   @default("update")
  isPinned    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([isPinned, publishedAt(sort: Desc)])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  name      String?
  category  String
  subject   String
  message   String   @db.Text
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}

/// Fixed-window HTTP rate limit counters (serverless-safe).
model RateLimitBucket {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

/// First-party product analytics (privacy-safe properties only).
model ProductAnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  userId     String?
  sessionId  String?
  distinctId String?
  funnel     String?
  properties Json?
  createdAt  DateTime @default(now())

  @@index([event, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([funnel, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model SystemEvent {
  id        String   @id @default(cuid())
  level     String
  category  String
  message   String   @db.Text
  metadata  Json?
  userId    String?
  path      String?
  createdAt DateTime @default(now())

  @@index([level, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
}
