# Prisma Postgres / PostgreSQL (required)
# Prisma Console → your database → Connect → copy connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional aliases (Vercel / Prisma integration may inject these)
# POSTGRES_URL=
# PRISMA_DATABASE_URL=

# Required — generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL (must match the domain in the browser)
# Local:  http://localhost:3000
# Live:   https://www.ichingoracle.de
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required for AI interpretations (DeepSeek — add to .env.local)
# DEEPSEEK_API_KEY=sk-...
# Optional override (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Resend (email verification)
# RESEND_API_KEY=re_PxpvpoGV_DtVwuKDZrxrZYhjd4FrVkBcB
# EMAIL_FROM=I Ching Oracle <noreply@yourdomain.com>
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: cron endpoint for batch credit refills (POST /api/cron/credits-refill)
# CRON_SECRET=generate-a-long-random-string

# Stripe (Premium subscription)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_1TZXZcEeFRS8zDDks5WTor6t  # recurring monthly price ID from Stripe Dashboard
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: cron endpoint for batch credit refills (POST /api/cron/credits-refill)
# CRON_SECRET=generate-a-long-random-string

# SEO (canonical URL + Search Console + optional PostHog)
# NEXT_PUBLIC_GSC_VERIFICATION=your-google-site-verification-code

# Product analytics (PostHog — client + server; consent-gated on client)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_API_KEY=phc_...  # optional server-only key (defaults to NEXT_PUBLIC_POSTHOG_KEY)

# Google Analytics (optional, consent-gated)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXX

# Admin (comma-separated emails with /admin access)
# ADMIN_EMAILS=you@example.com

# Error monitoring (optional)
# SENTRY_DSN=
