# Prisma Postgres / PostgreSQL (required)
# Prisma Console → your database → Connect → copy connection string
#
# Runtime (pooled — use for app queries on Vercel/serverless):
#   Neon/Supabase: use the *pooler* connection string (often port 6543)
#   Prisma Accelerate: prisma://… (replaces DATABASE_URL when enabled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# Migrations only (direct/non-pooled — never used by lib/prisma.ts at runtime):
#   Local: can match DATABASE_URL if you have no pooler
#   Production: use direct Postgres URL (not PgBouncer transaction mode)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#
# Optional Prisma runtime tuning (lib/prisma.ts applies defaults on serverless)
# PRISMA_CONNECTION_LIMIT=1
# PRISMA_POOL_TIMEOUT=20
# PRISMA_CONNECT_TIMEOUT=10
# PRISMA_LOG_QUERIES=true

# Optional aliases (Vercel / Prisma integration may inject these)
# POSTGRES_URL=
# PRISMA_DATABASE_URL=

# Required — generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL (must match the domain in the browser)
# Local:  http://localhost:3000
# Live:   https://www.ichingoracle.de
AUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required for AI interpretations (DeepSeek — add to .env.local)
# DEEPSEEK_API_KEY=sk-...
# Optional override (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# Closed beta program
# BETA_INVITE_ONLY=true
# BETA_CREDITS_BONUS=50

# Resend (verification + lifecycle emails)
# RESEND_API_KEY=re_...
# EMAIL_FROM=I Ching Oracle <noreply@yourdomain.com>
# EMAIL_FROM_ADDRESS=I Ching Oracle <noreply@yourdomain.com>
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron jobs (POST with Authorization: Bearer <CRON_SECRET>)
# /api/cron/credits-refill — daily credit refresh
# /api/cron/email/daily-oracle — daily guidance emails (07:00 UTC)
# /api/cron/email/weekly-reflection — weekly summaries (Mon 08:00 UTC)
# /api/cron/email/re-engagement — inactive user nudges (09:00 UTC)
# CRON_SECRET=generate-a-long-random-string

# Stripe (Premium subscription)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_1TZXZcEeFRS8zDDks5WTor6t  # recurring monthly price ID from Stripe Dashboard
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# SEO (canonical URL + Search Console + optional PostHog)
# NEXT_PUBLIC_GSC_VERIFICATION=your-google-site-verification-code

# Product analytics (PostHog — client capture + admin dashboard queries)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_API_KEY=phc_...  # optional server capture key
# POSTHOG_PERSONAL_API_KEY=phx_...  # required for admin analytics (query:read scope)
# POSTHOG_PROJECT_ID=12345  # Project settings → Project ID
# POSTHOG_API_HOST=https://us.posthog.com  # optional; derived from NEXT_PUBLIC_POSTHOG_HOST

# Google Analytics (optional, consent-gated)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXX

# Admin (comma-separated emails with /admin access)
# ADMIN_EMAILS=you@example.com

# Error monitoring (optional)
# SENTRY_DSN=
