generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified            DateTime?
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  image                    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  premiumUntil         DateTime?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String?
  subscriptionStatus   String? @default("free")
  preferredLanguage    String  @default("de")

  accounts Account[]
  sessions Session[]
  readings      Reading[]
  dailyOracles  DailyOracle[]
  dailyStreak   Int @default(0)
  lastDailyVisit DateTime?
}

model Reading {
  id                  String   @id @default(cuid())
  userId              String
  question            String
  hexagram            Int
  primaryHexagramName String?
  lineValues          String
  changingLines       String?
  transformedHexagram Int?
  finalHexagramName   String?
  interpretation         String   @db.Text
  interpretationPending  Boolean  @default(false)
  isPremiumReading       Boolean  @default(false)
  interpretationMode     String   @default("traditional")
  summary                String?  @db.Text
  category               String   @default("general")
  isFavorite             Boolean  @default(false)
  notes                  String?  @db.Text
  language               String   @default("de")
  createdAt              DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite])
  @@index([userId, category])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyOracle {
  id                String   @id @default(cuid())
  userId            String?
  visitorKey        String?
  date              DateTime @db.Date
  hexagramNumber    Int
  lineValues        String
  oracleMessage     String   @db.Text
  emotionalInsight  String   @db.Text
  recommendedAction String   @db.Text
  caution           String   @db.Text
  reflectionQuote   String   @db.Text
  luckyFocus        String
  energyLevel       Int      @default(50)
  energyTheme       String   @default("balanced")
  interpretation    String   @db.Text
  isFavorite        Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@unique([visitorKey, date])
  @@index([userId, date(sort: Desc)])
  @@index([visitorKey, date(sort: Desc)])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
